---
const base = import.meta.env.BASE_URL;
---

<div class="container">
  <div class="main-content">
    <div class="logo-container">
      <img class="logo-icon" src={`${base}/assets/logo.png`} alt="Pacto logo" />
      <div class="logo-text">pacto</div>
    </div>

    <div class="tagline">
      <span class="tagline-dynamic" id="taglineDynamic"></span>
    </div>

    <a href="#" class="download-btn" id="downloadBtn">
      <span id="downloadText">Download Pacto</span>
    </a>

    <div class="platform-note" id="platformNote">
      Available for Windows, macOS & Linux
    </div>

    <div class="all-downloads">
      <button class="all-downloads-toggle" id="toggleDownloads">Show All Downloads</button>
      <div class="downloads-list" id="downloadsList"></div>
    </div>
  </div>

  <div class="social-icons">
    <a href="https://discord.gg/trux4q8V" target="_blank" rel="noopener" aria-label="Discord">
      <img src={`${base}/assets/discord.svg`} alt="Discord" />
    </a>
    <a href="https://github.com/covenant-gov/pacto-docs" target="_blank" rel="noopener" aria-label="GitBook">
      <img src={`${base}/assets/gitbook.svg`} alt="GitBook" />
    </a>
  </div>
</div>

<script src="../scripts/platform.ts"></script>
