{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pacto-demo",
  "version": "0.2.0",
  "identifier": "io.pacto.demo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "pacto-demo",
        "minWidth": 400,
        "width": 1000,
        "minHeight": 400,
        "height": 800,
        "resizable": true,
        "maximized": true,
        "backgroundThrottling": "throttle",
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "$APPDATA/cache/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGMDhCRkUyNUZDM0Q1NEIKUldSTDFjTmY0cjhJTHgxZVlNbE5JbC9QZHhwdTRITDFGK3c3Y2VMN0llQlF3ZmgrN2JnRE9CWmMK",
      "endpoints": [
        "https://github.com/covenant-gov/pacto-app/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "macos": {
        "minimumSystemVersion": "10.15"
      }
    }
  }
}
