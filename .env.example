# Optional: override JSON-RPC URLs for the embedded wallet (viem public clients).
# Comma-separated = first URL is primary, rest are fallbacks (same order as viem fallback transport).
# Leave unset to use built-in public defaults in `src/lib/wallet/chains.ts`.
# Do not commit real API keys in tracked files; copy to `.env` (gitignored) for local use.
#
# VITE_WALLET_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# VITE_WALLET_RPC_OPTIMISM=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# VITE_WALLET_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional: Ethereum mainnet JSON-RPC URL used only for Chainlink price feed eth_call
# (Rust / Tauri). Not read from VITE_* — set in the shell or OS env for the desktop app.
# PACTO_CHAINLINK_PRICE_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Or reuse the first URL from:
# PACTO_WALLET_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- pacto-gov (Nave Pirata) — Sepolia example from covenant-gov deploy ---
# Unsuffixed names apply to all networks; `_SEPOLIA` overrides for that network only.
# PACTO_NAVE_PIRATA_FACTORY=0x44E42cf7b2DadDe6D5fc27B57625EaF3e3D41316
# PACTO_NAV_MASTER_QUARTERMASTER=0xE9C111428E23bd68C892785A6566DFc160358af1
# PACTO_NAV_MASTER_MUTINY=0xeA647c49a3594EEb3Cf0f38f705F34e036d3733B
# PACTO_NAV_MASTER_TREASURY_AUTHORITY=0x3AfD425EEFC54d4d97f610C47D4a3cEAE0FeC298
# PACTO_NAV_MASTER_SQUAD_ADMIN=0x85A7B39ED76b84efd85619F6df939c711b14DB54
# PACTO_NAV_MASTER_SQUAD_ADMIN_EXT=0x55B4e8df8DC23e4f414025e252Db26cbA22e25F1
# PACTO_NAVE_PIRATA_REGISTRY=0x45127C1c92741C0dA38e1A73fbb97a8a2C46770f
# PACTO_HATS=0x3bc1A0Ad72417f2d411118085256fC53CBdDd137
# PACTO_ROLE_HAT_CLONES_FACTORY=0xB240e490980b3EF11c30d7476a40f43B3311Ad58
# PACTO_ROLE_HAT_UPGRADER=0x327f1B3cdcabe6F1BC934bed768032B7b42906f7

# Safe bundle used by pacto-gov factory (Safe 1.4.x on Sepolia); also overrides standalone Safe deploy when set.
# PACTO_SAFE_PROXY_FACTORY=0x4e1DCf7AD4e460CfD30791CCC4F9c8a4f820ec67
# PACTO_SAFE_SINGLETON=0x41675C099F32341bf84BFc5382aF534df5C7461a
